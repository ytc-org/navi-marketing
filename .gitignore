# ─── THIS REPO IS PUBLIC ───────────────────────────────────────────────────
# Brand artifacts are confidential. They live in a local artifacts/ folder
# on each user's machine and must NEVER be committed.
artifacts/*
!artifacts/.gitkeep
!artifacts/README.md

# Google Search Console service account JSON.
# Distributed via 1Password — gives full read access to Navi's GSC property.
# Each user drops their copy at ./credentials.json (repo root).
# This MUST stay gitignored. Do not rename, do not commit, do not move.
credentials.json
credentials.*.json

# Environment (API keys)
.env
.env.local

# Generated outputs — local only
outputs/*
!outputs/.gitkeep

# Run logs — local only
tracking/*
!tracking/.gitkeep

# CLI job state (fork-and-detach wrapper) — local only
jobs/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Claude Code — user-local permission overrides; shared settings live in .claude/settings.json
.claude/settings.local.json
